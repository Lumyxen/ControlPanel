+function initModelManagement(root) {
+    const listContainer = root.querySelector("#models-list-container");
+    const addBtn = root.querySelector("#add-model-btn");
+    const modal = root.querySelector("#add-model-modal");
+    const closeModalBtn = root.querySelector("#close-model-modal");
+    const searchInput = root.querySelector("#model-search-input");
+    const resultsContainer = root.querySelector("#model-search-results");
+    
+    if (!listContainer || !addBtn || !modal) return;
+    
+    let currentModels = [];
+    let remoteModelsCache = [];
+    
+    // Render the local list of models
+    const renderList = () => {
+        listContainer.innerHTML = "";
+        if (currentModels.length === 0) {
+            listContainer.innerHTML = '<div style="padding:16px;color:var(--muted);text-align:center;">No models configured.</div>';
+            return;
+        }
+        
+        currentModels.forEach((model, index) => {
+            const div = document.createElement("div");
+            div.className = "model-item";
+            div.innerHTML = `
+                <div class="model-info">
+                    <div class="model-name">${model.name}</div>
+                    <div class="model-id">${model.id}</div>
+                </div>
+                <div class="model-actions">
+                    <button class="btn" data-action="remove" data-index="${index}" aria-label="Remove model">Remove</button>
+                </div>
+            `;
+            listContainer.appendChild(div);
+        });
+    };
+    
+    // Load current models from backend
+    const loadLocalModels = async () => {
+        try {
+            const res = await getModels();
+            currentModels = res.data || [];
+            renderList();
+        } catch (e) {
+            console.error("Failed to load models", e);
+            listContainer.innerHTML = '<div style="padding:16px;color:var(--ef-red);">Failed to load models.</div>';
+        }
+    };
+    
+    // Handle Remove
+    listContainer.addEventListener("click", async (e) => {
+        if (e.target.dataset.action === "remove") {
+            const idx = parseInt(e.target.dataset.index);
+            if (!isNaN(idx)) {
+                currentModels.splice(idx, 1);
+                renderList();
+                await updateModels(currentModels);
+            }
+        }
+    });
+    
+    // Open Modal
+    addBtn.addEventListener("click", async () => {
+        modal.classList.add("open");
+        searchInput.value = "";
+        resultsContainer.innerHTML = '<div style="padding:10px;color:var(--muted);">Loading OpenRouter models...</div>';
+        
+        try {
+            if (remoteModelsCache.length === 0) {
+                const res = await getRemoteModels();
+                remoteModelsCache = res.data || [];
+            }
+            resultsContainer.innerHTML = '<div style="padding:10px;color:var(--muted);">Type to search available models...</div>';
+            searchInput.focus();
+        } catch (e) {
+            resultsContainer.innerHTML = '<div style="padding:10px;color:var(--ef-red);">Failed to fetch OpenRouter models.</div>';
+        }
+    });
+    
+    // Close Modal
+    const closeModal = () => modal.classList.remove("open");
+    closeModalBtn.addEventListener("click", closeModal);
+    
+    // Search Logic
+    searchInput.addEventListener("input", (e) => {
+        const query = e.target.value.toLowerCase();
+        if (!query) {
+            resultsContainer.innerHTML = '<div style="padding:10px;color:var(--muted);">Type to search...</div>';
+            return;
+        }
+        
+        // Filter by substring (not strictly start-to-finish)
+        const matches = remoteModelsCache.filter(m => 
+            (m.name && m.name.toLowerCase().includes(query)) || 
+            (m.id && m.id.toLowerCase().includes(query))
+        ).slice(0, 50); // Limit results
+        
+        resultsContainer.innerHTML = "";
+        if (matches.length === 0) {
+            resultsContainer.innerHTML = '<div style="padding:10px;">No matches found</div>';
+            return;
+        }
+        
+        matches.forEach(m => {
+            const div = document.createElement("div");
+            div.className = "search-result-item";
+            div.innerHTML = `
+                <div class="model-name">${m.name}</div>
+                <div class="model-id" style="font-size:0.75rem;opacity:0.8;">${m.id}</div>
+                <div class="model-id" style="font-size:0.7rem;opacity:0.6;">Context: ${m.context_length || "?"} | Provider: ${m.provider || "Unknown"}</div>
+            `;
+            div.addEventListener("click", async () => {
+                // Add model
+                const newModel = {
+                    id: m.id,
+                    name: m.name,
+                    provider: m.provider,
+                    context_length: m.context_length || 8192,
+                    max_tokens: (m.top_provider && m.top_provider.max_completion_tokens) || 8192
+                };
+                
+                // Check duplicate
+                if (!currentModels.find(existing => existing.id === newModel.id)) {
+                    currentModels.push(newModel);
+                    renderList();
+                    await updateModels(currentModels);
+                }
+                closeModal();
+            });
+            resultsContainer.appendChild(div);
+        });
+    });
+    
+    // Initial load
+    loadLocalModels();
+}
