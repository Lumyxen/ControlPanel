{
  "manifest_version": 2,
  "name": "CtrlPanel Passwords",
  "version": "0.1.0",
  "description": "Injects CtrlPanel password chooser widgets into login fields.",
  "permissions": [
    "storage",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": [
      "background/vault-crypto.js",
      "background/background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "CtrlPanel Passwords"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://127.0.0.1:8080/*",
        "http://localhost:8080/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "browser_style": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ctrlpanel-passwords@local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
